{
	"name": "perbasi-tower-management",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "cross-env NODE_ENV=development vite dev",
		"build": "cross-env NODE_ENV=production vite build",
		"preview": "cross-env NODE_ENV=production vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"auth:migrate": "auth migrate --config src/lib/server/auth/provider.ts --yes",
		"auth:migrate:dev": "cross-env NODE_ENV=development auth migrate --config src/lib/server/auth/provider.ts --yes",
		"auth:migrate:prod": "cross-env NODE_ENV=production auth migrate --config src/lib/server/auth/provider.ts --yes",
		"db:migrate": "node scripts/db-migrate.mjs",
		"db:migrate:dev": "cross-env NODE_ENV=development node scripts/db-migrate.mjs",
		"db:migrate:prod": "cross-env NODE_ENV=production node scripts/db-migrate.mjs",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^24",
		"@types/pg": "^8.20.0",
		"auth": "^1.6.20",
		"cross-env": "^10.1.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"better-auth": "^1.6.20",
		"better-sqlite3": "^12.11.1",
		"dotenv": "^17.4.2",
		"kysely": "^0.29.2",
		"pg": "^8.22.0"
	}
}
